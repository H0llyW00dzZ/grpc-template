---
# Suppress all diagnostics in auto-generated C++ protobuf and gRPC files.
# These files are generated by buf generate and must not be edited manually.
# The generated code targets Protobuf C++ 7.x; the system library (3.21.x)
# differs, causing expected ABI mismatches — all suppressed intentionally.
#
# -ferror-limit=0 prevents clangd from aborting with "Too many errors emitted,
# stopping now" when the generated code references macros/symbols unavailable
# in the installed system protobuf headers.
If:
  PathMatch: [".*pkg/gen-cpp/.*"]
Diagnostics:
  Suppress: ["*"]
  ClangTidy:
    Remove: ["*"]
CompileFlags:
  Add: ["-w", "-ferror-limit=0"]
Index:
  Background: Skip
